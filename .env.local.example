# Supabase — copiez ce fichier en `.env.local` et renseignez vos valeurs.
# Project Settings → API dans le dashboard Supabase.

NEXT_PUBLIC_SUPABASE_URL=https://VOTRE-PROJET.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=VOTRE_CLE_ANON

# Clé service-role : SERVEUR UNIQUEMENT (calcul des points, settling des matchs).
# Ne jamais préfixer par NEXT_PUBLIC_ ni l'exposer au client.
SUPABASE_SERVICE_ROLE_KEY=VOTRE_CLE_SERVICE_ROLE

# Bzzoiro Sports API (données football) — SERVEUR UNIQUEMENT.
# Token sur https://sports.bzzoiro.com/register/
BZZOIRO_API_KEY=VOTRE_TOKEN_BZZOIRO

# Secret protégeant la route /api/settle (calcul des points / cron).
# Générez une valeur aléatoire : openssl rand -hex 16
CRON_SECRET=VOTRE_SECRET_CRON

# Origine canonique pour les métadonnées / sitemap / robots. OPTIONNEL :
# en prod Netlify injecte `URL` automatiquement ; à défaut on retombe sur
# http://localhost:3000. À renseigner si vous voulez forcer un domaine précis.
# NEXT_PUBLIC_SITE_URL=https://votre-domaine.fr
